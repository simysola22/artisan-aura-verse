# ─────────────────────────────────────────────────────────────────────────────
# PMP — Environment variable reference
#
# Copy this file to backend/.env and fill in values for local development.
# NEVER commit a .env file with real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (VITE_* are bundled into the browser — never put secrets here) ──

# Base URL for the real backend API.
# Leave empty to run the frontend in full mock mode (no backend needed).
VITE_API_BASE_URL=

# Force mock mode even when VITE_API_BASE_URL is set.
VITE_USE_MOCK_API=false

# Clerk publishable key — frontend public config, safe to bundle in browser.
# Never use VITE_CLERK_PUBLISHABLE_KEY as a backend secret.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key

# ── Backend server ────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Production target: Railway PostgreSQL.
# Example (local Docker):  postgres://pmp:pmp_dev_password@localhost:5432/pmp_dev
# Example (Railway):       postgres://user:pass@containers-us-west-xxx.railway.app:5432/railway
DATABASE_URL=postgres://pmp:pmp_dev_password@localhost:5432/pmp_dev

# ── Clerk authentication ──────────────────────────────────────────────────────
# CLERK_SECRET_KEY: backend only — NEVER set VITE_ prefix, never commit, never log.
# Production target: set as an environment variable on Render.
# Obtain from: Clerk Dashboard → API Keys → Secret keys
CLERK_SECRET_KEY=sk_test_replace_with_your_secret_key

# SESSION_SECRET: NOT required. Clerk owns session lifecycle.
# JWT_SECRET: NOT required. Clerk owns token signing. Custom JWT signing was
#             removed in Stage 2.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# Production: set to your Vercel frontend URL.
CORS_ORIGIN=http://localhost:5000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Cache (optional) ──────────────────────────────────────────────────────────
# Leave blank to use the in-memory cache (not suitable for multiple instances).
# Set to a Redis-compatible URL to use a distributed cache.
# Example:  redis://localhost:6379
# Example:  rediss://user:pass@redis.example.com:6380
REDIS_URL=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# S3-compatible storage (required when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_DRIVER=console
EMAIL_FROM=noreply@example.com

# SMTP settings (required when EMAIL_DRIVER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
