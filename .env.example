# ─────────────────────────────────────────────────────────────────────────────
# PMP — Environment variable reference
#
# Copy this file to backend/.env and fill in values for local development.
# NEVER commit a .env file with real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (VITE_* are bundled into the browser — never put secrets here) ──

# Base URL for the real backend API.
# Leave empty to run the frontend in full mock mode (no backend needed).
VITE_API_BASE_URL=

# Force mock mode even when VITE_API_BASE_URL is set.
VITE_USE_MOCK_API=false

# ── Backend server ────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Example (local Docker):  postgres://pmp:pmp_dev_password@localhost:5432/pmp_dev
# Example (managed):       postgres://user:pass@db.example.com:5432/pmp_prod?sslmode=require
DATABASE_URL=postgres://pmp:pmp_dev_password@localhost:5432/pmp_dev

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 32 characters.
# Generate a secure value:  openssl rand -hex 32
JWT_SECRET=replace_with_a_secure_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
CORS_ORIGIN=http://localhost:5000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Window duration in milliseconds and max requests per window per IP.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Cache (optional) ──────────────────────────────────────────────────────────
# Leave blank to use the in-memory cache (not suitable for multiple instances).
# Set to a Redis-compatible URL to use a distributed cache.
# Example:  redis://localhost:6379
# Example:  rediss://user:pass@redis.example.com:6380
REDIS_URL=

# ── Storage ───────────────────────────────────────────────────────────────────
# local = write files to STORAGE_LOCAL_DIR (dev only, not multi-instance safe)
# s3    = use S3-compatible object storage (required for production)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# S3-compatible storage (required when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# console = log emails to stdout (dev only)
# smtp    = send via SMTP (configure below)
EMAIL_DRIVER=console
EMAIL_FROM=noreply@example.com

# SMTP settings (required when EMAIL_DRIVER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
